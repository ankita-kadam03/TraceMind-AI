{
  "title": "TraceMind AI — Observability",
  "uid": "tracemind-ai",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{
        "expr": "tracemind_requests_total",
        "legendFormat": "Requests"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2,
      "title": "Avg LLM Latency (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{
        "expr": "rate(tracemind_llm_latency_ms_sum[1m]) / rate(tracemind_llm_latency_ms_count[1m])",
        "legendFormat": "Avg Latency"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3000 }, { "color": "red", "value": 8000 }] } } }
    },
    {
      "id": 3,
      "title": "Avg Grounding Score",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{
        "expr": "tracemind_grounding_score",
        "legendFormat": "Grounding"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.75 }] } } }
    },
    {
      "id": 4,
      "title": "Hallucination Risk",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{
        "expr": "tracemind_hallucination_score",
        "legendFormat": "Hallucination"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "red", "value": 0.6 }] } } }
    },
    {
      "id": 5,
      "title": "Emotion Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [{
        "expr": "tracemind_emotion_count",
        "legendFormat": "{{emotion}}"
      }],
      "options": { "pieType": "pie", "displayLabels": ["name", "percent"] }
    },
    {
      "id": 6,
      "title": "LLM Latency Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 4 },
      "targets": [{
        "expr": "rate(tracemind_llm_latency_ms_sum[1m]) / rate(tracemind_llm_latency_ms_count[1m])",
        "legendFormat": "LLM Latency (ms)"
      },
      {
        "expr": "rate(tracemind_total_latency_ms_sum[1m]) / rate(tracemind_total_latency_ms_count[1m])",
        "legendFormat": "Total Latency (ms)"
      }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 7,
      "title": "Emotion Confidence Score Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{
        "expr": "tracemind_emotion_confidence",
        "legendFormat": "{{emotion}} confidence"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 8,
      "title": "RAG Retrieval Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "expr": "rate(tracemind_rag_latency_ms_sum[1m]) / rate(tracemind_rag_latency_ms_count[1m])",
        "legendFormat": "RAG Latency (ms)"
      }],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 9,
      "title": "Tokens Generated Over Time",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "targets": [{
        "expr": "rate(tracemind_tokens_generated_total[1m])",
        "legendFormat": "Tokens/sec"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 10,
      "title": "Grounding Score Over Time",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "targets": [{
        "expr": "tracemind_grounding_score",
        "legendFormat": "Grounding Score"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.75 }] } } }
    }
  ],
  "time": { "from": "now-30m", "to": "now" }
}

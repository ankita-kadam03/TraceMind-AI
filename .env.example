# ============================================
# VoiceEmotionRAG Configuration
# Copy this to .env and fill in your values
# ============================================

# === LLM Provider ===
# Options: "grok" or "ollama"
LLM_PROVIDER=grok

# Grok AI (xAI) - https://console.x.ai
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-2

# Ollama (local fallback) - https://ollama.ai
OLLAMA_MODEL=mistral
OLLAMA_HOST=http://localhost:11434

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000

# === Speech Recognition ===
WHISPER_MODEL=base  # Options: tiny, base, small, medium, large
SAMPLE_RATE=16000

# === RAG Configuration ===
CHROMA_DIR=vectorDB
DATA_DIR=data
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# === Observability ===
OTEL_EXPORTER=console  # Options: console, jaeger
JAEGER_HOST=localhost
JAEGER_PORT=4317
PROMETHEUS_PORT=9464
